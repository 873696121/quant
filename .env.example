# ===========================================
# Quant 量化交易系统 - 环境配置
# ===========================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 根据部署环境修改对应配置
# 3. 本地开发使用 LOCAL_ 前缀配置
# 4. 云服务器部署使用 CLOUD_ 前缀配置

# ===========================================
# 部署模式
# ===========================================
# deployment: local | cloud
DEPLOYMENT=local

# ===========================================
# 本地开发配置 (DEPLOYMENT=local 时使用)
# ===========================================
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=quant2026
LOCAL_DB_NAME=quant

LOCAL_REDIS_HOST=localhost
LOCAL_REDIS_PORT=6379
LOCAL_REDIS_PASSWORD=

# ===========================================
# 云服务器配置 (DEPLOYMENT=cloud 时使用)
# ===========================================
# 你的云服务器 IP
CLOUD_HOST=你的云服务器IP

# MySQL 配置 (Docker 部署)
CLOUD_DB_HOST=${CLOUD_HOST}  # 默认同 CLOUD_HOST，或单独指定
CLOUD_DB_PORT=3306
CLOUD_DB_USER=root
CLOUD_DB_PASSWORD=quant2026
CLOUD_DB_NAME=quant

# Redis 配置 (Docker 部署)
CLOUD_REDIS_HOST=${CLOUD_HOST}  # 默认同 CLOUD_HOST，或单独指定
CLOUD_REDIS_PORT=6379
CLOUD_REDIS_PASSWORD=

# ===========================================
# 应用配置 (通用)
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
DEBUG=false

# 安全配置
SECRET_KEY=your-production-secret-key-change-this-in-production

# ===========================================
# 数据源配置
# ===========================================
DATA_SOURCE=akshare
TUSHARE_TOKEN=

# ===========================================
# QMT 实盘配置 (可选)
# ===========================================
QMT_HOST=localhost
QMT_PORT=58610
QMT_USER=
QMT_PASSWORD=
